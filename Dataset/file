### What is the performing product in each regions?

high_region = data.groupby(["State","Product"])["Total Sale"].sum().reset_index()
display(pd.DataFrame(high_region))

# Creating a visual aid of the data

plt.figure(figsize=(15,10))
sn.barplot(data=high_region, x="State", y ="Total Sale",hue="Product")
plt.xticks(rotation=90)
plt.title("Which is The Performing Product in each State?",family= "Algerian",
          fontsize=20,
          color="blue")
plt.show()
